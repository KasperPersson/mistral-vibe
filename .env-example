# Mistral Vibe Environment Variables
# 
# This file shows the environment variables that can be used with Mistral Vibe.
# Copy this file to .env and fill in your actual API keys.
# 
# IMPORTANT: Never commit your actual .env file with real API keys!
# The .env file is already in .gitignore for security.

# Mistral API Key
# Get your API key from https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: Alternative API key for staging environment
STAGING_MISTRAL_API_KEY=your_staging_api_key_here

# Optional: Proxy settings
# HTTPS_PROXY=https://your-proxy:port
# HTTP_PROXY=http://your-proxy:port

# Optional: Additional environment variables for custom providers
# CUSTOM_PROVIDER_API_KEY=your_custom_api_key_here

# Optional: Debug mode
# DEBUG_MODE=true